# Maintainer: cryptob1 <cryptob1@users.noreply.github.com>
pkgname=oflow-bin
_pkgname=oflow
pkgver=0.2.0
pkgrel=1
pkgdesc="Fast, accurate voice-to-text dictation for Linux (Wayland/Hyprland), powered by Groq Whisper. Hold F8, speak, paste into any app."
arch=('x86_64')
url="https://github.com/cryptob1/oflow"
license=('MIT')
# Runtime: ydotool (paste) + ydotoold, playerctl (media pause),
# gtk4-layer-shell/python-gobject/python-cairo (recording overlay),
# webkit2gtk-4.1 (Tauri UI). The AppImage bundles the Python backend.
depends=('ydotool' 'playerctl' 'gtk4-layer-shell' 'python-gobject' 'python-cairo'
         'webkit2gtk-4.1' 'jq' 'fuse2' 'hicolor-icon-theme')
provides=('oflow')
conflicts=('oflow')
install="${_pkgname}.install"
options=(!strip)

_appimage="oflow_${pkgver}_amd64.AppImage"
source=("${_appimage}::${url}/releases/download/v${pkgver}/${_appimage}"
        "${_pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
noextract=("${_appimage}")
# TODO: replace SKIP with real sums once the v0.2.0 release AppImage is built:
#   updpkgsums   (or: sha256sum oflow_0.2.0_amd64.AppImage)
sha256sums=('SKIP'
            'SKIP')

prepare() {
    chmod +x "${_appimage}"
    ./"${_appimage}" --appimage-extract
}

package() {
    # App (Tauri UI + bundled Python backend) → /opt, launcher → /usr/bin/oflow
    install -Dm755 "${srcdir}/${_appimage}" "${pkgdir}/opt/${_pkgname}/${_pkgname}.AppImage"
    install -dm755 "${pkgdir}/usr/bin"
    ln -s "/opt/${_pkgname}/${_pkgname}.AppImage" "${pkgdir}/usr/bin/oflow"

    cd "${srcdir}/${_pkgname}-${pkgver}"

    # Recording overlay (found by the backend at /usr/share/oflow/oflow-osd.py)
    install -Dm755 oflow-osd.py "${pkgdir}/usr/share/oflow/oflow-osd.py"

    # Socket controller for the Hyprland push-to-talk keybinding
    install -Dm755 scripts/oflow-ctl "${pkgdir}/usr/bin/oflow-ctl"

    # Desktop entry + icons (from the AppImage)
    if [[ -f "${srcdir}/squashfs-root/oflow.desktop" ]]; then
        sed "s|^Exec=.*|Exec=/usr/bin/oflow|" "${srcdir}/squashfs-root/oflow.desktop" \
            > "oflow.desktop.tmp"
        install -Dm644 "oflow.desktop.tmp" "${pkgdir}/usr/share/applications/oflow.desktop"
    fi
    if [[ -d "${srcdir}/squashfs-root/usr/share/icons" ]]; then
        cp -a "${srcdir}/squashfs-root/usr/share/icons" "${pkgdir}/usr/share/"
    fi

    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${_pkgname}/LICENSE"
}
